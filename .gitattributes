# Unity recommended .gitattributes

# Auto detect text files and perform LF normalization
* text=auto

# Unity YAML files
*.cs        text eol=lf
*.shader    text eol=lf
*.mat       text eol=lf
*.prefab    text eol=lf
*.unity     text eol=lf
*.asset     text eol=lf
*.asmdef    text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.psd       binary
*.pdf       binary
*.mp3       binary
*.wav       binary
*.ogg       binary
*.aif       binary
*.ttf       binary
*.otf       binary
*.fbx       binary
*.obj       binary
*.plist     binary
*.apk       binary
*.aab       binary
